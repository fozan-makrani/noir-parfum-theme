{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Marquee text",
      "default": "FREE SHIPPING OVER ₹999 · NEW ARRIVALS · OUD · FLORAL · WOODY · LUXURY FRAGRANCES"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#c9a84c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "speed",
      "default": 22,
      "min": 10,
      "label": "Animation speed (seconds)",
      "max": 40,
      "step": 2
    }
  ],
  "presets": [{ "name": "Marquee Banner" }]
}
{% endschema %}

<style>
  #mq-{{ section.id }} {
    --mq-bg: {{ section.settings.bg_color }};
    --mq-color: {{ section.settings.text_color }};
    --mq-speed: {{ section.settings.speed }}s;
  }
</style>

<div id="mq-{{ section.id }}" class="mq-wrap">
  <div class="mq-track">
    {% assign words = section.settings.text | split: ' · ' %}
    {% for i in (1..2) %}
      {% for word in words %}
        {% unless word == '' %}
          <span class="mq-word">{{ word }}</span>
          <span class="mq-sep"></span>
        {% endunless %}
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
.mq-wrap {
  overflow: hidden;
  padding: 0.75rem 0;
  white-space: nowrap;
  width: 100%;
  position: relative;
  background-color: var(--mq-bg);
}

.mq-wrap::before,
.mq-wrap::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 70px;
  z-index: 2;
  pointer-events: none;
}

.mq-wrap::before {
  left: 0;
  background: linear-gradient(to right, var(--mq-bg), transparent);
}

.mq-wrap::after {
  right: 0;
  background: linear-gradient(to left, var(--mq-bg), transparent);
}

.mq-track {
  display: inline-flex;
  align-items: center;
  animation: mq-scroll var(--mq-speed) linear infinite;
  will-change: transform;
}

.mq-track:hover {
  animation-play-state: paused;
}

.mq-word {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--mq-color);
  display: inline-block;
  transform-origin: center bottom;
  animation: mq-stretch 3s ease-in-out infinite;
}

.mq-word:nth-child(2n)  { animation-delay: 0.6s; }
.mq-word:nth-child(3n)  { animation-delay: 1.2s; }
.mq-word:nth-child(4n)  { animation-delay: 1.8s; }
.mq-word:nth-child(5n)  { animation-delay: 2.4s; }
.mq-word:nth-child(6n)  { animation-delay: 3.0s; }
.mq-word:nth-child(7n)  { animation-delay: 3.6s; }
.mq-word:nth-child(8n)  { animation-delay: 4.2s; }

.mq-sep {
  display: inline-block;
  height: 1px;
  background-color: var(--mq-color);
  margin: 0 18px;
  flex-shrink: 0;
  opacity: 0.45;
  animation: mq-line 3s ease-in-out infinite;
}

.mq-sep:nth-child(2n) { animation-delay: 0.6s; }
.mq-sep:nth-child(3n) { animation-delay: 1.2s; }
.mq-sep:nth-child(4n) { animation-delay: 1.8s; }

@keyframes mq-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

@keyframes mq-stretch {
  0%,  100% { transform: scaleX(1);    letter-spacing: 0.20em; opacity: 0.7; }
  50%        { transform: scaleX(1.06); letter-spacing: 0.28em; opacity: 1;   }
}

@keyframes mq-line {
  0%,  100% { width: 16px; opacity: 0.3; }
  50%        { width: 30px; opacity: 0.7; }
}
{% endstylesheet %}